// The botch — Prisma スキーマ（PostgreSQL）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. メンバー
// ============================================================
model Member {
  id        String   @id @default(uuid())
  name      String   @unique // 表示名（ゆうき、ゆうへい等）
  fullName  String   @map("full_name") // 姓（内山、大崎等）
  initial   String   @db.Char(1) // アバター用
  colorBg   String   @default("bg-gray-100") @map("color_bg")
  colorText String   @default("text-gray-700") @map("color_text")
  paypayId  String?  @map("paypay_id") // PayPay ID（@xxx）
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  otokogiEventsPaid      OtokogiEvent[]
  otokogiParticipations  OtokogiParticipant[]
  warikanManaged         WarikanEvent[]        @relation("WarikanManager")
  warikanParticipations  WarikanParticipant[]
  warikanExpensesPaid    WarikanExpense[]
  warikanExpenseDebtors  WarikanExpenseDebtor[]
  settlementsFrom        WarikanSettlement[]   @relation("SettlementFrom")
  settlementsTo          WarikanSettlement[]   @relation("SettlementTo")
  eventsCreated          Event[]               @relation("EventCreator")
  eventParticipations    EventParticipant[]

  @@map("members")
}

// ============================================================
// 2. 男気イベント
// ============================================================
model OtokogiEvent {
  id        String   @id @default(uuid())
  eventDate DateTime @map("event_date") @db.Date
  eventName String   @map("event_name") @db.VarChar(100)
  payerId   String   @map("payer_id")
  amount    Int      // 支払額（円）
  place     String?  @db.VarChar(100)
  hasAlbum  Boolean  @default(false) @map("has_album")
  memo      String?
  eventId   String?  @map("event_id") // カレンダーイベント紐付け
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  payer        Member               @relation(fields: [payerId], references: [id])
  participants OtokogiParticipant[]
  event        Event?               @relation(fields: [eventId], references: [id])

  @@index([eventDate(sort: Desc)])
  @@index([payerId])
  @@map("otokogi_events")
}

// 男気イベント参加者（多対多）
model OtokogiParticipant {
  otokogiEventId String @map("otokogi_event_id")
  memberId       String @map("member_id")

  otokogiEvent OtokogiEvent @relation(fields: [otokogiEventId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id])

  @@id([otokogiEventId, memberId])
  @@map("otokogi_participants")
}

// ============================================================
// 3. 割り勘イベント
// ============================================================
enum WarikanStatus {
  ENTERING   @map("明細入力中")
  PAYING     @map("支払待ち")
  CLOSED     @map("クローズ")

  @@map("warikan_status")
}

model WarikanEvent {
  id              String        @id @default(uuid())
  eventName       String        @map("event_name") @db.VarChar(200)
  status          WarikanStatus @default(ENTERING)
  detailDeadline  DateTime?     @map("detail_deadline") @db.Date
  paymentDeadline DateTime?     @map("payment_deadline") @db.Date
  memo            String?
  managerId       String?       @map("manager_id")
  walicaUrl       String?       @map("walica_url") @db.VarChar(255)
  eventId         String?       @map("event_id") // カレンダーイベント紐付け
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // リレーション
  manager      Member?              @relation("WarikanManager", fields: [managerId], references: [id])
  participants WarikanParticipant[]
  expenses     WarikanExpense[]
  settlements  WarikanSettlement[]
  event        Event?               @relation(fields: [eventId], references: [id])

  @@index([status])
  @@map("warikan_events")
}

// 割り勘参加者
model WarikanParticipant {
  warikanEventId String @map("warikan_event_id")
  memberId       String @map("member_id")

  warikanEvent WarikanEvent @relation(fields: [warikanEventId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id])

  @@id([warikanEventId, memberId])
  @@map("warikan_participants")
}

// 割り勘立替明細
model WarikanExpense {
  id             String   @id @default(uuid())
  warikanEventId String   @map("warikan_event_id")
  payerId        String   @map("payer_id")
  description    String   @db.VarChar(200) // 内容（コート代、ボール等）
  amount         Int      // 金額（円）
  createdAt      DateTime @default(now()) @map("created_at")

  warikanEvent WarikanEvent        @relation(fields: [warikanEventId], references: [id], onDelete: Cascade)
  payer        Member              @relation(fields: [payerId], references: [id])
  debtors      WarikanExpenseDebtor[]

  @@map("warikan_expenses")
}

// 割り勘立替の対象者（誰の分か）
model WarikanExpenseDebtor {
  expenseId String @map("expense_id")
  memberId  String @map("member_id")

  expense WarikanExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member  Member         @relation(fields: [memberId], references: [id])

  @@id([expenseId, memberId])
  @@map("warikan_expense_debtors")
}

// 割り勘精算結果（A→B 送金指示）
model WarikanSettlement {
  id             String    @id @default(uuid())
  warikanEventId String    @map("warikan_event_id")
  fromMemberId   String    @map("from_member_id")
  toMemberId     String    @map("to_member_id")
  amount         Int       // 送金額（円）
  isPaid         Boolean   @default(false) @map("is_paid")
  isReceived     Boolean   @default(false) @map("is_received")
  paidAt         DateTime? @map("paid_at")
  receivedAt     DateTime? @map("received_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  warikanEvent WarikanEvent @relation(fields: [warikanEventId], references: [id], onDelete: Cascade)
  fromMember   Member       @relation("SettlementFrom", fields: [fromMemberId], references: [id])
  toMember     Member       @relation("SettlementTo", fields: [toMemberId], references: [id])

  @@index([warikanEventId])
  @@map("warikan_settlements")
}

// ============================================================
// 4. カレンダーイベント
// ============================================================
enum EventType {
  TRIP     @map("旅行")
  HANGOUT  @map("飲み会")
  ACTIVITY @map("アクティビティ")
  OTHER    @map("その他")

  @@map("event_type")
}

model Event {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(200)
  date        DateTime  @db.Date // 開始日
  endDate     DateTime? @map("end_date") @db.Date // 終了日（複数日の場合）
  description String?
  eventType   EventType @default(HANGOUT) @map("event_type")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // リレーション
  createdBy    Member             @relation("EventCreator", fields: [createdById], references: [id])
  participants EventParticipant[]
  otokogiEvents OtokogiEvent[]
  warikanEvents WarikanEvent[]

  @@index([date])
  @@map("events")
}

// カレンダーイベント参加者
model EventParticipant {
  eventId  String @map("event_id")
  memberId String @map("member_id")

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id])

  @@id([eventId, memberId])
  @@map("event_participants")
}
